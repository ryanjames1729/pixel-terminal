#!/usr/bin/env python3
"""
pixel-http-server — lightweight HTTP test server for packet inspection.
Serves GET and POST forms on the local network IP; logs every request to stdout.
Usage: pixel-http-server [port]   (default port: 8080)
"""
import http.server, json, socket, sys, urllib.parse
from datetime import datetime

PORT = int(sys.argv[1]) if len(sys.argv) > 1 else 8080

# ── Resolve local network IP ──────────────────────────────────────────────────

def local_ip():
    try:
        s = socket.socket(socket.AF_INET, socket.SOCK_DGRAM)
        s.connect(('8.8.8.8', 80))
        ip = s.getsockname()[0]
        s.close()
        return ip
    except Exception:
        return '127.0.0.1'

IP = local_ip()

# ── HTML templates (dark theme matching Pixel Terminal) ───────────────────────

_CSS = """
*{box-sizing:border-box;margin:0;padding:0}
body{font-family:ui-monospace,'Cascadia Code',monospace;background:#0f1117;color:#e2e8f0;
     padding:2.5rem 2rem;max-width:680px;margin:0 auto;line-height:1.5}
h1{color:#818cf8;font-size:1.15rem;margin-bottom:.2rem}
.sub{color:#4a5568;font-size:.78rem;margin-bottom:2.5rem}
.sub a{color:#6ee7b7;text-decoration:none}
h2{color:#6ee7b7;font-size:.72rem;text-transform:uppercase;letter-spacing:.1em;
   margin:1.75rem 0 .7rem}
form{background:#141924;border:1px solid #1e2535;border-radius:8px;
     padding:1.25rem;display:flex;flex-direction:column;gap:.6rem}
input,textarea{background:#0f1117;border:1px solid #2d3748;border-radius:5px;
               color:#e2e8f0;font-family:inherit;font-size:.82rem;
               padding:.45rem .65rem;width:100%;outline:none}
input:focus,textarea:focus{border-color:#818cf8}
textarea{resize:vertical;height:76px}
button{align-self:flex-start;background:#818cf8;border:none;border-radius:5px;
       color:#fff;cursor:pointer;font-family:inherit;font-size:.82rem;
       padding:.45rem 1.2rem;transition:background .15s}
button:hover{background:#6366f1}
.badge{display:inline-block;font-size:.68rem;padding:.15rem .5rem;border-radius:3px;
       margin-right:.4rem;vertical-align:middle}
.get{background:#1a3a2a;color:#6ee7b7}.post{background:#2a1a3a;color:#a78bfa}
.result{background:#141924;border:1px solid #1e2535;border-left:3px solid #6ee7b7;
        border-radius:8px;margin-top:2rem;padding:1.25rem}
.result h2{margin-top:0}
pre{color:#94a3b8;font-size:.78rem;white-space:pre-wrap;word-break:break-all;margin-top:.6rem}
"""

_PAGE = """<!DOCTYPE html><html lang="en">
<head><meta charset="utf-8"><title>Pixel HTTP Test Server</title>
<style>{css}</style></head>
<body>
<h1>▸ Pixel HTTP Test Server</h1>
<p class="sub">
  Local: <a href="http://{ip}:{port}/">http://{ip}:{port}/</a>
  &nbsp;·&nbsp; Loopback: <a href="http://127.0.0.1:{port}/">http://127.0.0.1:{port}/</a>
  &nbsp;·&nbsp; capture traffic with <code>tcpdump</code> or <code>tshark</code>
</p>

<h2><span class="badge get">GET</span> Query string</h2>
<form method="GET" action="/get">
  <input name="q"     placeholder="search query" />
  <input name="token" placeholder="token (optional)" />
  <button>Send GET</button>
</form>

<h2><span class="badge post">POST</span> Form data</h2>
<form method="POST" action="/post">
  <input  name="username" placeholder="username" />
  <input  name="password" type="password" placeholder="password" />
  <input  name="target"   placeholder="target host or URL (optional)" />
  <textarea name="notes"  placeholder="notes / payload"></textarea>
  <button>Send POST</button>
</form>

<h2><span class="badge post">POST</span> JSON body</h2>
<form id="jf">
  <textarea id="jb" placeholder='{{"key":"value","token":"abc123","target":"192.168.1.1"}}'></textarea>
  <button type="button" onclick="postJson()">Send JSON POST</button>
</form>

<script>
function postJson(){{
  var body = document.getElementById('jb').value;
  fetch('/post', {{
    method: 'POST',
    headers: {{'Content-Type': 'application/json'}},
    body: body
  }}).then(r => r.text()).then(html => {{
    document.open(); document.write(html); document.close();
  }}).catch(e => alert('Fetch error: ' + e));
}}
</script>
{result}
</body></html>"""

_RESULT = """
<div class="result">
<h2>Response</h2>
<pre>{content}</pre>
</div>"""

# ── Request handler ───────────────────────────────────────────────────────────

# ANSI colour constants matching the app palette
_I = '\x1b[38;2;129;140;248m'   # indigo
_G = '\x1b[38;2;110;231;183m'   # mint/green
_P = '\x1b[38;2;167;139;250m'   # purple
_D = '\x1b[38;2;74;85;104m'     # dim
_Y = '\x1b[38;2;251;191;36m'    # yellow
_R = '\x1b[0m'

class _Handler(http.server.BaseHTTPRequestHandler):

    def log_message(self, fmt, *args):  # override default stderr logging
        ts   = datetime.now().strftime('%H:%M:%S')
        meth = self.command
        col  = _G if meth == 'GET' else _P
        print(f'{_D}[{ts}]{_R} {col}{meth:<4}{_R} {self.path}', flush=True)

    # ── helpers ───────────────────────────────────────────────────────────────

    def _send_html(self, html: str, code: int = 200) -> None:
        body = html.encode('utf-8')
        self.send_response(code)
        self.send_header('Content-Type', 'text/html; charset=utf-8')
        self.send_header('Content-Length', str(len(body)))
        self.end_headers()
        self.wfile.write(body)

    def _read_body(self) -> bytes:
        n = int(self.headers.get('Content-Length', 0))
        return self.rfile.read(n) if n > 0 else b''

    def _page(self, result: str = '') -> str:
        return _PAGE.format(css=_CSS, ip=IP, port=PORT, result=result)

    # ── GET ───────────────────────────────────────────────────────────────────

    def do_GET(self) -> None:
        parsed = urllib.parse.urlparse(self.path)
        qs     = urllib.parse.parse_qs(parsed.query)

        if qs:
            params  = {k: v[0] for k, v in qs.items()}
            content = (
                f'Method  : GET\n'
                f'Path    : {parsed.path}\n'
                f'Params  :\n{json.dumps(params, indent=10)}'
            )
            result = _RESULT.format(content=content)
        else:
            result = ''

        self._send_html(self._page(result))

    # ── POST ──────────────────────────────────────────────────────────────────

    def do_POST(self) -> None:
        raw = self._read_body()
        ct  = self.headers.get('Content-Type', '')

        if 'application/json' in ct:
            try:
                parsed_body = json.dumps(json.loads(raw), indent=10)
                kind        = 'JSON'
            except json.JSONDecodeError:
                parsed_body = raw.decode('utf-8', errors='replace')
                kind        = 'Raw'
        elif 'application/x-www-form-urlencoded' in ct:
            fields      = urllib.parse.parse_qs(raw.decode('utf-8', errors='replace'))
            parsed_body = json.dumps({k: v[0] for k, v in fields.items()}, indent=10)
            kind        = 'Form'
        else:
            parsed_body = raw.decode('utf-8', errors='replace')
            kind        = 'Body'

        content = (
            f'Method  : POST\n'
            f'Path    : {self.path}\n'
            f'Type    : {ct}\n'
            f'{kind:<7} :\n{parsed_body}'
        )
        result = _RESULT.format(content=content)
        self._send_html(self._page(result))

# ── Startup banner ────────────────────────────────────────────────────────────

print()
print(f'\x1b[1m{_I}  ▸ pixel-http-server{_R}')
print(f'{_D}  ──────────────────────────────────────{_R}')
print(f'  {_G}✓{_R}  Local    {_I}http://{IP}:{PORT}/{_R}')
print(f'  {_G}✓{_R}  Loopback {_I}http://127.0.0.1:{PORT}/{_R}')
print(f'{_D}  GET · POST form · POST JSON{_R}')
print(f'{_D}  Press ⌃C to stop{_R}')
print()

# ── Serve ─────────────────────────────────────────────────────────────────────

server = http.server.HTTPServer(('0.0.0.0', PORT), _Handler)
try:
    server.serve_forever()
except KeyboardInterrupt:
    print(f'\n{_D}  Server stopped.{_R}\n')
